local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("Syrexhub Modded", "Grapevine")

-- Main Tab
local Main = Window:NewTab("Combat")
local Section = Main:NewSection("Aimbot Settings")

-- Variables
_G.AimbotEnabled = false
_G.TeamCheck = true

-- Original Script Loader
local function LoadOriginalScript()
    loadstring(game:HttpGet("https://raw.githubusercontent.com/Joshingtonn123/JoshScript/refs/heads/main/SyrexhubSniperOrDie"))()
end

-- Aimbot Toggle
Section:NewToggle("Enable Aimbot", "Locks onto targets", function(state)
    _G.AimbotEnabled = state
    if state then
        LoadOriginalScript() -- Bubuksan ang original sniper script
    end
end)

-- Team Check Toggle (Enemy Only)
Section:NewToggle("Only Enemy (Team Check)", "Will not target teammates", function(state)
    _G.TeamCheck = state
end)

-- Logic for Aimbot with Team Check
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local RunService = game:GetService("RunService")

RunService.RenderStepped:Connect(function()
    if _G.AimbotEnabled then
        local target = nil
        local shortestDistance = math.huge

        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Humanoid") and v.Character.Humanoid.Health > 0 then
                
                -- Heto yung Enemy Only Logic
                local isEnemy = true
                if _G.TeamCheck and v.Team == LocalPlayer.Team then
                    isEnemy = false
                end

                if isEnemy then
                    local screenPos, onScreen = workspace.CurrentCamera:WorldToViewportPoint(v.Character.HumanoidRootPart.Position)
                    if onScreen then
                        local mag = (Vector2.new(screenPos.X, screenPos.Y) - Vector2.new(LocalPlayer:GetMouse().X, LocalPlayer:GetMouse().Y)).Magnitude
                        if mag < shortestDistance then
                            target = v
                            shortestDistance = mag
                        end
                    end
                end
            end
        end

        if target then
            workspace.CurrentCamera.CFrame = CFrame.new(workspace.CurrentCamera.CFrame.Position, target.Character.HumanoidRootPart.Position)
        end
    end
end)
